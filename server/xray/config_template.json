{
  "log": {
    "loglevel": "warning",
    "access": "/var/log/xray/access.log",
    "error": "/var/log/xray/error.log"
  },
  "api": {
    "tag": "api",
    "services": ["HandlerService", "StatsService", "RoutingService"]
  },
  "stats": {},
  "policy": {
    "levels": {
      "0": {
        "statsUserUplink": true,
        "statsUserDownlink": true
      }
    },
    "system": {
      "statsInboundUplink": true,
      "statsInboundDownlink": true,
      "statsOutboundUplink": true,
      "statsOutboundDownlink": true
    }
  },
  "dns": {
    "servers": [
      {
        "address": "1.1.1.1",
        "skipFallback": false
      },
      {
        "address": "8.8.8.8",
        "skipFallback": true
      },
      {
        "address": "77.88.8.8",
        "domains": ["geosite:category-ru"],
        "skipFallback": true
      }
    ],
    "queryStrategy": "UseIPv4",
    "disableCache": false,
    "tag": "dns-internal"
  },
  "inbounds": [
    {
      "tag": "api",
      "port": 10085,
      "listen": "127.0.0.1",
      "protocol": "dokodemo-door",
      "settings": {
        "address": "127.0.0.1"
      }
    },
    {
      "tag": "vless-reality",
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "dest": "REALITY_DEST_PLACEHOLDER",
          "serverNames": ["REALITY_SNI_PLACEHOLDER"],
          "privateKey": "REALITY_PRIVATE_KEY_PLACEHOLDER",
          "shortIds": ["REALITY_SHORT_ID_PLACEHOLDER"]
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"],
        "routeOnly": true
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIPv4"
      },
      "streamSettings": {
        "sockopt": {
          "mark": 255,
          "tcpMptcp": true,
          "tcpNoDelay": true
        }
      }
    },
    {
      "tag": "blocked",
      "protocol": "blackhole"
    },
    {
      "tag": "warp",
      "protocol": "socks",
      "settings": {
        "servers": [{"address": "127.0.0.1", "port": 40000}]
      }
    }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
