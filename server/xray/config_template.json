{
  "log": {
    "loglevel": "warning",
    "access": "/var/log/xray/access.log",
    "error": "/var/log/xray/error.log"
  },
  "api": {
    "tag": "api",
    "services": ["HandlerService", "StatsService", "RoutingService"]
  },
  "stats": {},
  "policy": {
    "levels": {
      "0": {
        "statsUserUplink": true,
        "statsUserDownlink": true
      }
    },
    "system": {
      "statsInboundUplink": true,
      "statsInboundDownlink": true,
      "statsOutboundUplink": true,
      "statsOutboundDownlink": true
    }
  },
  "dns": {
    "servers": [
      {
        "address": "https+local://dns.google/dns-query",
        "skipFallback": true
      },
      {
        "address": "https+local://cloudflare-dns.com/dns-query",
        "skipFallback": false
      }
    ],
    "queryStrategy": "UseIPv4"
  },
  "inbounds": [
    {
      "tag": "api",
      "port": 10085,
      "listen": "127.0.0.1",
      "protocol": "dokodemo-door",
      "settings": {
        "address": "127.0.0.1"
      }
    },
    {
      "tag": "vless-reality",
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "dest": "REALITY_DEST_PLACEHOLDER",
          "serverNames": ["REALITY_SNI_PLACEHOLDER"],
          "privateKey": "REALITY_PRIVATE_KEY_PLACEHOLDER",
          "shortIds": ["REALITY_SHORT_ID_PLACEHOLDER"]
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls", "quic"],
        "routeOnly": true
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIPv4"
      }
    },
    {
      "tag": "blocked",
      "protocol": "blackhole"
    },
    {
      "tag": "warp",
      "protocol": "socks",
      "settings": {
        "servers": [{"address": "127.0.0.1", "port": 40000}]
      }
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "inboundTag": ["api"],
        "outboundTag": "api"
      },
      {
        "type": "field",
        "outboundTag": "blocked",
        "ip": ["geoip:private"]
      },
      {
        "type": "field",
        "outboundTag": "warp",
        "domain": [
          "domain:notebooklm.google",
          "domain:notebooklm.google.com",
          "domain:aistudio.google.com"
        ]
      },
      {
        "type": "field",
        "outboundTag": "direct",
        "domain": [
          "domain:sberbank.ru",
          "domain:tinkoff.ru",
          "domain:tbank.ru",
          "domain:vtb.ru",
          "domain:alfabank.ru",
          "domain:gazprombank.ru",
          "domain:raiffeisen.ru",
          "domain:sovcombank.ru",
          "domain:rosbank.ru",
          "domain:psbank.ru",
          "domain:uralsib.ru",
          "domain:mtsbank.ru",
          "domain:mkb.ru",
          "domain:pochtabank.ru",
          "domain:open.ru",
          "domain:tochka.com",
          "domain:ozon.bank",
          "domain:yandex.ru",
          "domain:yandex.com",
          "domain:yandex.net",
          "domain:ya.ru",
          "domain:yastatic.net",
          "domain:kinopoisk.ru",
          "domain:mts.ru",
          "domain:megafon.ru",
          "domain:beeline.ru",
          "domain:gosuslugi.ru",
          "domain:ozon.ru",
          "domain:wildberries.ru",
          "domain:vk.com",
          "domain:vk.ru",
          "domain:mail.ru",
          "domain:ok.ru",
          "domain:avito.ru",
          "domain:1c.ru"
        ]
      }
    ]
  }
}
