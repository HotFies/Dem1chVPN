# ═══════════════════════════════════════════
# 🛡️ Dem1chVPN — Environment Configuration
# Copy this file to .env and fill in values
# ═══════════════════════════════════════════

# Telegram Bot
BOT_TOKEN=
ADMIN_IDS=
PIN_CODE=0000

# Server
SERVER_IP=
SERVER_PORT=443

# Reality
REALITY_DEST=dl.google.com:443
REALITY_SNI=dl.google.com
REALITY_PRIVATE_KEY=
REALITY_PUBLIC_KEY=
REALITY_SHORT_ID=

# Database
DB_PATH=/opt/dem1chvpn/data/dem1chvpn.db

# Xray
XRAY_CONFIG_PATH=/usr/local/etc/xray/config.json
XRAY_BINARY=/usr/local/bin/xray
XRAY_INBOUND_TAG=vless-reality

# Subscription
SUB_HOST=127.0.0.1
SUB_PORT=8080
# SUB_DOMAIN auto-detected from VPS hostname (hostname -f)
# Override manually if using a custom domain
SUB_DOMAIN=
SUB_EXTERNAL_PORT=8443

# Features
ADGUARD_ENABLED=false
WARP_ENABLED=false
MTPROTO_ENABLED=false
